<t tx="karstenw.20260427093901.36">def __getattr__(self, a):
    
    """ Keys in the dictionaries are accessible as attributes.
    """ 
    
    if a in self: 
        return self[a]
        
    raise AttributeError( "'GraphStyles' object has no attribute '" + a + "'" )
    
