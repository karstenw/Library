<t tx="karstenw.20260427093516.1"># A graph that browses semantic relations like
# fish IsA animal
# tarbot IsExampleOf fish
# fin isPartOf fish

springgraph = ximport("springgraph")
# reload(springgraph)

graphbrowser = ximport("graphbrowser")
# reload(graphbrowser)

# import pattern.en

import os
import io
import pprint
pp=pprint.pprint

import pdb

# from os.path import basename



semantic_relations_explicit = {
    1   : "is_property_of",
    2   : "is_part_of",
    3   : "is_a",
    4   : "is_used_for",
    5   : "is_made_of",
    6   : "is_related_to",
    7   : "is_example_of",
    8   : "is_opposed_to",
    9   : "is_capable_of",
    10  : "is_desired_effect_of"
}

# Don't use these ones in rule files,
# they're derived automatically.
semantic_relations_implicit = {
    81  : "has_property",
    82  : "has_part",
    83  : "concrete_form",
    84  : "desired_result_of",
    87  : "has_example",
    89  : "implemented_by",
    90  : "has_possible_cause",                            
}

