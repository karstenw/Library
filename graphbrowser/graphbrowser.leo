<t tx="karstenw.20260427093901.9">def add_node(self, id, radius=15, style=STYLE_DEFAULT, root=False):
    
    """ Adds a node with given id to the graph.
    """
    
    if id in self.index:
        return self.index[id]
    
    node = GraphNode(self, id, radius, style)
    self.index[node.id] = node
    self.nodes.append(node)
    if root: 
        self.root = node
        
    return node
    
