    self.d = GraphNode(None).r * 2 * distance
    
    self.pathfinder = GraphShortestPath()
    
    self.styles = GraphStyles()
    self.styles.append(GraphStyle(STYLE_DEFAULT))
    self.alpha = 0
    
    self.pressed = None
    self.dragged = None
    self.clicked = None
    self.hovered = None
    
